<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password Length"
        android:textStyle="bold" />

    <com.google.android.material.slider.Slider
        android:id="@+id/lengthSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="8"
        android:valueTo="32"
        android:stepSize="1"
        android:value="16" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/uppercaseCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Uppercase (A-Z)"
        android:checked="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/lowercaseCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Lowercase (a-z)"
        android:checked="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/numbersCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Numbers (0-9)"
        android:checked="true" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/symbolsCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Symbols (!@#$...)"
        android:checked="true" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/generateButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Generate"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/generatedPasswordText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="12dp"
        android:background="?attr/colorSurfaceVariant"
        android:textIsSelectable="true" />

</LinearLayout>