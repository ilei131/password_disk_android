<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="com.passworddisk.app.ui.AuthFragment"
        android:label="Auth"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_auth_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.passworddisk.app.ui.HomeFragment"
        android:label="Passwords"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_addPassword"
            app:destination="@id/addPasswordFragment" />
        <action
            android:id="@+id/action_home_to_editPassword"
            app:destination="@id/editPasswordFragment" />
        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_home_to_totp"
            app:destination="@id/totpFragment" />
        <action
            android:id="@+id/action_home_to_auth"
            app:destination="@id/authFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/addPasswordFragment"
        android:name="com.passworddisk.app.ui.AddPasswordFragment"
        android:label="Add Password"
        tools:layout="@layout/fragment_add_password" />

    <fragment
        android:id="@+id/editPasswordFragment"
        android:name="com.passworddisk.app.ui.EditPasswordFragment"
        android:label="Edit Password"
        tools:layout="@layout/fragment_add_password">
        <argument
            android:name="passwordId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.passworddisk.app.ui.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_categories"
            app:destination="@id/categoriesFragment" />
        <action
            android:id="@+id/action_settings_to_cloudSync"
            app:destination="@id/cloudSyncFragment" />
        <action
            android:id="@+id/action_settings_to_backupToCloud"
            app:destination="@id/backupToCloudFragment" />
        <action
            android:id="@+id/action_settings_to_totp"
            app:destination="@id/totpFragment" />
    </fragment>

    <fragment
        android:id="@+id/backupToCloudFragment"
        android:name="com.passworddisk.app.ui.BackupToCloudFragment"
        android:label="Backup to Cloud"
        tools:layout="@layout/fragment_backup_to_cloud" />

    <fragment
        android:id="@+id/categoriesFragment"
        android:name="com.passworddisk.app.ui.CategoriesFragment"
        android:label="Categories"
        tools:layout="@layout/fragment_categories" />

    <fragment
        android:id="@+id/cloudSyncFragment"
        android:name="com.passworddisk.app.ui.CloudSyncFragment"
        android:label="Cloud Sync"
        tools:layout="@layout/fragment_cloud_sync">
        <action
            android:id="@+id/action_cloudSync_to_auth"
            app:destination="@id/authFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/totpFragment"
        android:name="com.passworddisk.app.ui.TotpFragment"
        android:label="2FA Generator"
        tools:layout="@layout/fragment_totp" />

</navigation>